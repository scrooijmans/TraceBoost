{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@ophiolite/contracts": ["../../../ophiolite/contracts/ts/ophiolite-contracts/src/index.ts"],
      "@traceboost/seis-contracts": ["../../contracts/ts/seis-contracts/src/index.ts"]
    },
    "strict": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "preserveSymlinks": true,
    "skipLibCheck": true,
    "types": ["svelte", "node"]
  },
  "include": ["src/**/*", "vite.config.ts"]
}
