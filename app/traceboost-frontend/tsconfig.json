{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@geoviz/data-models": ["../../../geoviz/packages/data-models/src/index.ts"],
      "@geoviz/chart-core": ["../../../geoviz/packages/chart-core/src/index.ts"],
      "@geoviz/renderer": ["../../../geoviz/packages/renderer/src/index.ts"],
      "@geoviz/domain-geoscience": ["../../../geoviz/packages/domain-geoscience/src/index.ts"],
      "@geoviz/svelte": ["../../../geoviz/packages/svelte/src/index.ts"],
      "@traceboost/seis-contracts": ["../../contracts/ts/seis-contracts/src/index.ts"]
    },
    "strict": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["svelte"]
  },
  "include": ["src/**/*", "vite.config.ts"]
}
